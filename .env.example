NEXT_PUBLIC_CESIUM_ION_TOKEN=replace_with_your_cesium_ion_token

# Backboard (https://backboard.io) is the only AI infrastructure provider used
# by the GridTwin control room. Server-only: never exposed to the browser.
BACKBOARD_API_KEY=replace_with_your_backboard_api_key
BACKBOARD_API_BASE_URL=https://app.backboard.io/api
# Explicit mock-mode switch. Unset (or no BACKBOARD_API_KEY) defaults to mock
# mode, so `npm run dev`, `npm run check`, and `npm run backboard:status`
# all work offline with no credentials. Set to false to force live mode.
BACKBOARD_MOCK_MODE=false

# --- Optional: per-role assistant id / model overrides -----------------
# Reserved for a possible future feature; NOT read by any code today. The
# assistant roster in src/lib/backboard/assistants.ts is always resolved by
# name (find-or-create) via getAssistantManifest, and the model for each
# role is always chosen by src/lib/backboard/model-router.ts from
# Backboard's capability catalog. See docs/backboard/model-routing.md.
# Left here, commented out, as a documented placeholder only.
# BACKBOARD_MARKET_ANALYST_ASSISTANT_ID=
# BACKBOARD_RENEWABLE_ANALYST_ASSISTANT_ID=
# BACKBOARD_DISPATCH_PLANNER_ASSISTANT_ID=
# BACKBOARD_RISK_REVIEWER_ASSISTANT_ID=
# BACKBOARD_CHIEF_DISPATCH_OFFICER_ASSISTANT_ID=
# BACKBOARD_MODEL_OVERRIDE=
