# FreeSolo / Flash: managed train + student adapter deploy
FREESOLO_API_KEY=
# OpenRouter: reward MCQ judge in model/grpo/judge.py (small LM, not FreeSolo)
OPENROUTER_API_KEY=
# WANDB_API_KEY=...   # picked up automatically by `flash train` when [wandb] is set
# Optional judge overrides
# TECHTO_JUDGE_BASE_URL=https://openrouter.ai/api/v1
# TECHTO_JUDGE_MODEL=qwen/qwen-2.5-7b-instruct

# Toronto 2D map (MapLibre GL). Optional: falls back to the OpenFreeMap
# "bright" style below if unset. Never put a secret in a NEXT_PUBLIC_ var.
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/bright

# Backboard (https://backboard.io) is the only AI infrastructure provider
# used by TechTO's virtual planning department. Server-only: never exposed
# to the browser. Live API required (no mock adapter).
BACKBOARD_API_KEY=replace_with_your_backboard_api_key
BACKBOARD_API_BASE_URL=https://app.backboard.io/api
# Optional: allow Backboard web search on operator / research turns.
BACKBOARD_ENABLE_WEB_SEARCH=false

# Citizen-reaction population simulator: "freesolo" (live FreeSolo only).
TECHTO_CITIZEN_REACTION_PROVIDER=freesolo

# TechTO open-city PopulationProvider: "synthetic" | "census"
# census loads data/processed/census_personas.json (or CENSUS_PERSONAS_PATH)
TECHTO_POPULATION_PROVIDER=synthetic
# CENSUS_PERSONAS_PATH=

# FreeSolo (server-only). Required when TECHTO_CITIZEN_REACTION_PROVIDER=freesolo.
FREESOLO_BASE_URL=
FREESOLO_REACTION_MODEL_ALIAS=techto-citizen-reaction
FREESOLO_TIMEOUT_SECONDS=45

# Optional FastAPI transit-core base (services/transit-core).
NEXT_PUBLIC_TRANSIT_API_BASE_URL=http://localhost:8000

# Transit data repository: "fixture" (local src/data/transit) or "mongo"
# (Atlas; run `npm run mongo:bootstrap` first). Tests should use fixture.
TECHTO_REPOSITORY_PROVIDER=fixture

# MongoDB Atlas (server-only; never expose to the browser).
# Used by `npm run mongo:status`, `npm run mongo:bootstrap`, and mongo repository.
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@hackthe6ix.tsafr7k.mongodb.net/?appName=HackThe6ix
# Optional read-only URI for agent run_python (falls back to MONGODB_URI).
# Prefer an Atlas user with find/aggregate only (no insert/update/delete).
# MONGODB_URI_READONLY=
MONGODB_DATABASE=techto
MONGODB_SEARCH_INDEX=techto-search
MONGODB_VECTOR_INDEX=techto-memory-vector
MONGODB_STREAM_WORKSPACE=
MONGODB_STREAM_PROCESSOR=

# Default demo scenario id (synthetic-fixture load imbalance at Union).
TECHTO_DEMO_SCENARIO=departure-406-412
