# Toronto 2D map (MapLibre GL). Optional: falls back to the OpenFreeMap
# "bright" style below if unset. Never put a secret in a NEXT_PUBLIC_ var.
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/bright

# Backboard (https://backboard.io) is the only AI infrastructure provider
# used by TwinTO's virtual planning department. Server-only: never exposed
# to the browser.
BACKBOARD_API_KEY=replace_with_your_backboard_api_key
BACKBOARD_API_BASE_URL=https://app.backboard.io/api
# Explicit mock-mode switch. Unset (or no BACKBOARD_API_KEY) defaults to mock
# mode, so `npm run dev`, `npm run check`, and `npm run backboard:status`
# all work offline with no credentials. Set to false to force live mode.
BACKBOARD_MOCK_MODE=false
# Optional: allow Backboard web search on operator / research turns.
BACKBOARD_ENABLE_WEB_SEARCH=false

# Citizen-reaction population simulator provider. Only "mock" is implemented
# on this branch (deterministic heuristic, never real Toronto opinion data).
# Later: freesolo. See src/lib/citizen-reaction/provider.ts.
TWINTO_CITIZEN_REACTION_PROVIDER=mock

# Transit data repository. Only "fixture" is implemented on this branch
# (local synthetic data under src/data/transit/). Later: mongo.
TWINTO_REPOSITORY_PROVIDER=fixture

# Default demo scenario id (synthetic-fixture load imbalance at Union).
TWINTO_DEMO_SCENARIO=departure-406-412
